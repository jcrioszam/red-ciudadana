{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://red-ciudadana-backend.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://red-ciudadana-backend.onrender.com",
    "REACT_APP_ENVIRONMENT": "production",
    "REACT_APP_BACKEND_URL": "https://red-ciudadana-backend.onrender.com"
  },
  "buildCommand": "npm run build",
  "outputDirectory": "build"
}
